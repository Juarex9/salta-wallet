# === Autenticación ===
JWT_SECRET=WJNIhd79whdJHSkdjs9SJD9n9Hn3jsDn/93ksN=

# === Base de Datos ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/salta_wallet?schema=public

# === Binance ===
BINANCE_API_KEY=test-api-key-binance-testnet
BINANCE_API_SECRET=test-api-secret-binance-testnet
BINANCE_TESTNET=true

# === AI ===
OPENAI_API_KEY=sk-proj-test-key-aqui

# === MercadoPago ===
MERCADOPAGO_ACCESS_TOKEN=APP_USR_TEST_1234567890

# === Desarrollo ===
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEBUG=salta:*
```

