# ============================================================================
# AUTENTICACIÓN CON AUTH0 v4.19.0 (REQUERIDO)
# ============================================================================

# Generar en https://auth0.com/
AUTH0_SECRET=use_node_to_generate_this_secret_randomly # $(node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here

# ============================================================================
# BASE DE DATOS - POSTGRESQL
# ============================================================================

DATABASE_URL=postgresql://user:password@localhost:5432/salta_wallet?schema=public

# ============================================================================
# BINANCE API (OPCIONAL - Para cripto)
# ============================================================================

BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=true  # Cambiar a false en producción

# ============================================================================
# AI / LLM MODELS (OPCIONAL - Para agente IA)
# ============================================================================

# Opción 1: OpenAI
OPENAI_API_KEY=sk-proj-your-key-here

# Opción 2: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Opción 3: Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=your-key-here

# ============================================================================
# MERCADOPAGO (OPCIONAL - Para pagos fiat)
# ============================================================================

MERCADOPAGO_ACCESS_TOKEN=APP_USR_your_token_here
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================================================
# MONITOREO (OPCIONAL - Para errores en producción)
# ============================================================================

SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_ENVIRONMENT=production

# ============================================================================
# ALMACENAMIENTO DE ARCHIVOS (OPCIONAL)
# ============================================================================

BLOB_READ_WRITE_TOKEN=vercel_blob_token_here

# ============================================================================
# URLS PÚBLICAS
# ============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_COINGECKO_API=https://api.coingecko.com/api/v3

# ============================================================================
# DESARROLLO
# ============================================================================

NODE_ENV=development
DEBUG=salta:*


